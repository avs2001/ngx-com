{
  "name": "ngx-com",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve integration --port 4500",
    "build": "ng build",
    "test": "ng test",
    "watch": "ng build --watch --configuration development",

    "lib:build": "ng build com --configuration production",
    "lib:build:watch": "ng build com --watch --configuration development",
    "lib:test": "ng test com",
    "lib:test:ci": "ng test com --watch=false",
    "lib:pack": "cd dist/com && npm pack",

    "demo:serve": "ng serve integration --port 4500",
    "demo:build": "ng build integration --configuration production --base-href /ngx-com/",

    "release:patch": "node scripts/release.mjs patch",
    "release:minor": "node scripts/release.mjs minor",
    "release:major": "node scripts/release.mjs major",
    "release:pre": "node scripts/release.mjs prerelease",
    "publish:lib": "node scripts/publish.mjs",
    "publish:dry": "node scripts/publish.mjs --dry-run",

    "ci": "npm run lib:build && npm run lib:test:ci",
    "ci:full": "npm run ci && npm run demo:build",

    "e2e": "playwright test --config=e2e/playwright.config.ts",
    "e2e:ui": "playwright test --config=e2e/playwright.config.ts --ui",
    "e2e:headed": "playwright test --config=e2e/playwright.config.ts --headed",
    "e2e:debug": "playwright test --config=e2e/playwright.config.ts --debug",
    "e2e:report": "playwright show-report",

    "build:lib": "ng build com --configuration production",
    "watch:lib": "ng build --watch --project com",
    "test:ci": "ng test com --watch=false"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@10.9.2",
  "dependencies": {
    "@angular/aria": "^21.2.0",
    "@angular/cdk": "~21.2.0",
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "@angular/router": "^21.0.0",
    "@tailwindcss/postcss": "^4.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-angular": "^0.577.0",
    "postcss": "^8.5.6",
    "rxjs": "~7.8.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.0",
    "@angular/cdk": "^21.2.0",
    "@angular/cli": "^21.0.1",
    "@angular/compiler-cli": "^21.0.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.1.12",
    "@vitest/browser-playwright": "^4.0.18",
    "jsdom": "^28.1.0",
    "ng-packagr": "^21.2.0",
    "playwright": "^1.58.2",
    "postcss": "^8.5.3",
    "tailwindcss": "^4.1.12",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8",
    "vitest-axe": "^0.1.0"
  }
}
